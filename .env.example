# ZROKY Environment Variables
# Copy to .env: cp .env.example .env

# General
NODE_ENV=development
LOG_LEVEL=debug

# API Server
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://zroky:zroky_dev_password@localhost:5432/zroky

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=zroky
CLICKHOUSE_PASSWORD=zroky_dev_password
CLICKHOUSE_DB=zroky

# Redis
REDIS_URL=redis://localhost:6379

# Auth (Clerk) — get from https://dashboard.clerk.com
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Billing (Stripe) — get from https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Engine Ports
SAFETY_PORT=8001
GROUNDING_PORT=8002
CONSISTENCY_PORT=8003
SYSTEM_PORT=8004
TRUST_COMPUTER_PORT=8005
HEALTH_CHECK_PORT=8006
